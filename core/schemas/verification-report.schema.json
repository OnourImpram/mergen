{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/TheGoatPsy/mergen/schemas/verification-report.schema.json",
  "title": "Mergen verification report",
  "description": "Machine-readable record of an independent verification pass. Companion to verification-report.md. Each task carries a confidence label so calibration is recorded, not assumed.",
  "type": "object",
  "required": ["schema_version", "feature_id", "verified_at", "summary", "tasks"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "const": "1.0" },
    "feature_id": { "type": "string" },
    "verified_at": { "type": "string", "format": "date-time", "description": "ISO-8601 timestamp of the verification pass" },
    "verifier": {
      "type": "object",
      "properties": {
        "tool": { "type": "string" },
        "mode": { "type": "string" },
        "agent": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "required": ["verdict", "human_review_required"],
      "properties": {
        "verdict": { "enum": ["pass", "conditional_pass", "fail"] },
        "risk_level": { "enum": ["tiny", "standard", "spec", "high-trust"] },
        "human_review_required": { "type": "boolean" },
        "human_review": {
          "type": "object",
          "description": "Machine-readable human sign-off state. When human_review_required is true, a strict gate requires status approved before a final pass.",
          "required": ["status"],
          "properties": {
            "status": { "enum": ["pending", "approved", "rejected"] },
            "reviewer": { "type": ["string", "null"] },
            "approved_at": { "type": ["string", "null"], "description": "ISO-8601 timestamp of approval, or null" },
            "evidence": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["risk_level"],
            "properties": { "risk_level": { "const": "high-trust" } }
          },
          "then": {
            "description": "A high-trust report must at minimum flag that human review is required. The flag is then honoured by a recorded human_review approval before a final pass, the same non-downgradable invariant the Governor decision carries for its tier.",
            "required": ["human_review_required"],
            "properties": { "human_review_required": { "const": true } }
          }
        }
      ]
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id", "claimed_status", "verified_status", "confidence"],
        "properties": {
          "task_id": { "type": "string" },
          "claimed_status": { "enum": ["done", "todo"] },
          "verified_status": { "enum": ["pass", "fail"] },
          "confidence": {
            "enum": ["extracted", "inferred", "ambiguous"],
            "description": "How the verdict is known, from the one confidence vocabulary defined in MERGEN_PRINCIPLES.md and mirrored by verify_core.CONFIDENCE. extracted means direct filesystem or test evidence. A verdict without evidence is fail, never an inferred pass."
          },
          "files_checked": { "type": "array", "items": { "type": "string" } },
          "tests_run": { "type": "array", "items": { "type": "string" } },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "failures": { "type": "array", "items": { "type": "string" } }
        },
        "allOf": [
          {
            "if": {
              "required": ["verified_status"],
              "properties": { "verified_status": { "const": "pass" } }
            },
            "then": {
              "description": "A pass must carry concrete evidence and cannot be ambiguous. A verdict without evidence is a fail, never an inferred or ambiguous pass.",
              "required": ["confidence"],
              "properties": { "confidence": { "enum": ["extracted", "inferred"] } },
              "anyOf": [
                { "required": ["files_checked"], "properties": { "files_checked": { "minItems": 1 } } },
                { "required": ["tests_run"], "properties": { "tests_run": { "minItems": 1 } } },
                { "required": ["evidence"], "properties": { "evidence": { "minItems": 1 } } }
              ]
            }
          }
        ]
      }
    },
    "policy_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["policy_id", "result", "reason"],
        "additionalProperties": false,
        "properties": {
          "policy_id": { "type": "string" },
          "result": { "enum": ["pass", "warn", "fail"] },
          "reason": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "description": "What produced this report, so tampering or staleness is detectable. Written by verify_core.compute_provenance. The report bytes are also hashed into a <report>.sha256 sidecar; verify_core --check-manifest recomputes and compares.",
      "properties": {
        "verifier_version": { "type": "string" },
        "source_commit": { "type": ["string", "null"], "description": "git HEAD of the verified root, or null outside a git work tree" },
        "working_tree_clean": { "type": ["boolean", "null"], "description": "whether the verified root had no uncommitted changes, or null outside a git work tree" },
        "tasks_state_sha256": { "type": "string", "description": "sha256 of the exact tasks-state file bytes the report verified" }
      }
    },
    "memory_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "status": { "enum": ["proposed", "applied"] },
          "target": { "type": "string" }
        }
      }
    }
  }
}
