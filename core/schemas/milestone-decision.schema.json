{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/OnourImpram/mergen/schemas/milestone-decision.schema.json",
  "title": "Mergen milestone supervision decision",
  "description": "Fail-closed milestone authority. Only a pass verdict may authorize advance. Fail and unverifiable always block.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "milestone_id",
    "evaluated_at",
    "verdict",
    "decision",
    "checks",
    "source",
    "authority"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "milestone_id": { "type": "string", "minLength": 1 },
    "evaluated_at": { "type": "string", "format": "date-time" },
    "verdict": { "enum": ["pass", "fail", "unverifiable"] },
    "decision": { "enum": ["advance", "block"] },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "result", "reason"],
        "properties": {
          "check_id": { "type": "string", "minLength": 1 },
          "result": { "enum": ["pass", "fail", "unverifiable"] },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "report": { "type": "string" },
        "report_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "tasks_state": { "type": "string" },
        "tasks_state_sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_commit": { "type": ["string", "null"] }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "implements_changes",
        "trusts_self_declared_independence"
      ],
      "properties": {
        "mode": { "const": "deterministic-separate-process" },
        "implements_changes": { "const": false },
        "trusts_self_declared_independence": { "const": false }
      }
    },
    "review_observation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_claim",
        "verdict_claim",
        "claimed_independent",
        "independence_verified",
        "used_as_positive_proof",
        "ignored_root_fields"
      ],
      "properties": {
        "reviewer_claim": { "type": ["string", "null"] },
        "verdict_claim": { "type": ["string", "null"] },
        "claimed_independent": { "type": "boolean" },
        "independence_verified": { "const": false },
        "used_as_positive_proof": { "const": false },
        "ignored_root_fields": {
          "type": "array",
          "items": {
            "enum": ["root", "workspace_root", "repository_root"]
          },
          "uniqueItems": true
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["verdict"],
        "properties": { "verdict": { "const": "pass" } }
      },
      "then": {
        "required": ["decision"],
        "properties": { "decision": { "const": "advance" } }
      },
      "else": {
        "required": ["decision"],
        "properties": { "decision": { "const": "block" } }
      }
    },
    {
      "if": {
        "required": ["decision"],
        "properties": { "decision": { "const": "advance" } }
      },
      "then": {
        "required": ["verdict"],
        "properties": { "verdict": { "const": "pass" } }
      }
    }
  ]
}
