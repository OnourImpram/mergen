# Normalize line endings deterministically across contributors and OSes.
* text=auto eol=lf

# Scripts that run on Unix must stay LF.
*.sh   text eol=lf
*.py   text eol=lf
*.md   text eol=lf

# Windows PowerShell scripts use CRLF.
*.ps1  text eol=crlf

# Never normalize compiled bytecode.
*.pyc  binary
