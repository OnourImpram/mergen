# Code ownership for review routing. The owner is requested for review on a pull
# request that touches the matching paths. The safety-critical surfaces are
# listed explicitly so a change to the verification engine, the Governor floor,
# the schemas, or the hooks always reaches the owner, even if a broad rule would
# already cover it.

# Default owner for everything.
*                                   @OnourImpram

# The deterministic core that proves work was done. Changes here change the
# guarantee, so they are owned explicitly.
/scripts/verify_core.py             @OnourImpram
/scripts/verify_report_lint.py      @OnourImpram
/scripts/governor_floor.py          @OnourImpram
/core/schemas/                      @OnourImpram
/core/hooks/                        @OnourImpram

# Single-source render contract and its drift gates.
/core/commands/                     @OnourImpram
/dist/                              @OnourImpram
/scripts/check_sync.py              @OnourImpram
/scripts/check_no_reference_text.py @OnourImpram

# Supply chain and CI.
/.github/                           @OnourImpram
/pyproject.toml                     @OnourImpram
