/scripts/verify_report_lint.py      @TheGoatPsy
/scripts/governor_floor.py          @TheGoatPsy
/core/schemas/                      @TheGoatPsy
/core/hooks/                        @TheGoatPsy

# Single-source render contract and its drift gates.
